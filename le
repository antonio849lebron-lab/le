<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Nuestro Libro</title>

<style>
body{
 margin:0;
 background:#111;
 font-family:Georgia, serif;
 overflow:hidden;
}

/* PORTADA */
.portada{
 position:absolute;
 width:100%;
 height:100%;
 background:#ff4d6d;
 color:white;
 display:flex;
 justify-content:center;
 align-items:center;
 flex-direction:column;
 z-index:10;
 transform-origin:left;
 transition:transform 1.5s ease;
}
.portada.abierta{ transform:rotateY(-120deg); }

/* LIBRO */
.libro{
 position:relative;
 width:100vw;
 height:100vh;
 perspective:2500px;
}

.pagina{
 position:absolute;
 width:50%;
 height:100%;
 top:0;
 left:50%;
 transform-origin:left;
 transform-style:preserve-3d;
 transition:transform 1s ease;
 background:white;
 box-shadow:-5px 0 25px rgba(0,0,0,0.6);
}

.pagina.volteada{ transform:rotateY(-180deg); }

.cara{
 position:absolute;
 width:100%;
 height:100%;
 backface-visibility:hidden;
 display:flex;
 justify-content:center;
 align-items:center;
 flex-direction:column;
 padding:30px;
 box-sizing:border-box;
 text-align:center;
}

.detras{
 background:#f2f2f2;
 transform:rotateY(180deg);
}

img{
 width:220px;
 border-radius:12px;
 margin:10px;
}

.texto{
 font-size:20px;
 max-width:500px;
 min-height:120px;
}
</style>
</head>

<body>

<div class="portada" id="portada">
 <h1>Antonio ❤️ [Nombre de ella]</h1>
 <button onclick="abrirLibro()">Abrir libro</button>
</div>

<div class="libro">

<div class="pagina" id="p1" style="z-index:3;">
 <div class="cara frente"><div class="texto" id="t1"></div></div>
 <div class="cara detras"><img src="foto1.jpg"></div>
</div>

<div class="pagina" id="p2" style="z-index:2;">
 <div class="cara frente"><img src="foto2.jpg"></div>
 <div class="cara detras"><div class="texto" id="t2"></div></div>
</div>

<div class="pagina" id="p3" style="z-index:1;">
 <div class="cara frente">
   <div class="texto" id="t3"></div>
   <button onclick="musica()">🎵 Nuestra canción</button>
 </div>
 <div class="cara detras"><h1>Te amo ❤️</h1></div>
</div>

</div>

<audio id="audio" src="cancion.mp3"></audio>
<audio id="hoja" src="hoja.mp3"></audio>

<script>
let paginas=document.querySelectorAll(".pagina");
let paginaActual=0;
let startX=0;

function abrirLibro(){
 document.getElementById("portada").classList.add("abierta");
 escribir("t1","Todo comenzó el día que te vi por primera vez...");
}

paginas.forEach((p,index)=>{
 p.addEventListener("mousedown",e=>startX=e.clientX);
 p.addEventListener("mouseup",e=>gesto(index,e.clientX));

 p.addEventListener("touchstart",e=>startX=e.touches[0].clientX);
 p.addEventListener("touchend",e=>gesto(index,e.changedTouches[0].clientX));
});

function gesto(index,endX){
 let diferencia=startX-endX;

 // pasar hacia adelante
 if(diferencia>80 && index===paginaActual){
   paginas[index].classList.add("volteada");
   document.getElementById("hoja").play();
   paginaActual++;

   if(paginaActual===1) escribir("t2","Hemos vivido momentos inolvidables...");
   if(paginaActual===2) escribir("t3","Eres lo más bonito que me ha pasado...");
 }

 // devolver hacia atrás
 if(diferencia<-80 && index===paginaActual-1){
   paginaActual--;
   paginas[paginaActual].classList.remove("volteada");
   document.getElementById("hoja").play();
 }
}

function escribir(id,texto){
 let i=0;
 let destino=document.getElementById(id);
 destino.innerHTML="";
 let intervalo=setInterval(()=>{
   destino.innerHTML+=texto.charAt(i);
   i++;
   if(i>=texto.length) clearInterval(intervalo);
 },40);
}

function musica(){
 document.getElementById("audio").play();
}
</script>

</body>
</html>
